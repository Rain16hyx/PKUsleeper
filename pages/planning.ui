  <property name="styleSheet">
   <string notr="true">#Form {
    background: #fffdf9;
    color: #25252a;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

QLabel {
    color: #28272c;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

#label {
    color: #222226;
    font-size: 32px;
    font-weight: 800;
}

#dateButton,
#settingsButton {
    min-height: 44px;
    border: 1px solid #e4d8cb;
    border-radius: 9px;
    background: #fffefa;
    color: #29272a;
    font-size: 16px;
}

#dateButton {
    min-width: 196px;
    padding: 0 18px;
}

#settingsButton {
    min-width: 48px;
    font-size: 21px;
}

#dateButton:hover,
#settingsButton:hover,
#pushButton:hover {
    border-color: #cfb99c;
    background: #fff8ed;
}

#avatarLabel {
    min-width: 48px;
    min-height: 48px;
    border-radius: 24px;
    background: #f6ddba;
    color: #a9141c;
    font-size: 25px;
    font-weight: 700;
}

#frame,
#frame_2,
#frame_3,
#legendFrame {
    background: #fffefd;
    border: 1px solid #e5d9cc;
    border-radius: 11px;
}

#label_2 {
    color: #25252a;
    font-size: 19px;
    font-weight: 800;
}

#subtitleLabel,
#tipLabel,
#legendTitle {
    color: #8a817a;
    font-size: 14px;
}

#headerIcon,
#resultIcon {
    min-width: 46px;
    min-height: 46px;
    border-radius: 23px;
    background: #f7e5ca;
    color: #b8151d;
    font-size: 25px;
    font-weight: 700;
}

#pushButton {
    min-width: 150px;
    min-height: 46px;
    border: 1px solid #e7cdb8;
    border-radius: 9px;
    background: #fffefa;
    color: #2a2729;
    font-size: 16px;
    font-weight: 700;
}

#pushButton_2 {
    min-width: 150px;
    min-height: 46px;
    border: none;
    border-radius: 9px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #cf1f27, stop:1 #ad121a);
    color: #ffffff;
    font-size: 17px;
    font-weight: 800;
}

#pushButton_2:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #dc2b33, stop:1 #bd1821);
}

#dayLabel,
#dayLabel_2,
#dayLabel_3,
#dayLabel_4,
#dayLabel_5,
#dayLabel_6,
