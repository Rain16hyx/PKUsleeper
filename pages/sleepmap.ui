  <property name="styleSheet">
   <string notr="true">#Form {
    background: #fffdf9;
    color: #25252a;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

QLabel {
    color: #28272c;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

#label {
    color: #222226;
    font-size: 32px;
    font-weight: 800;
}

#dateButton,
#settingsButton {
    min-height: 44px;
    border: 1px solid #e4d8cb;
    border-radius: 9px;
    background: #fffefa;
    color: #29272a;
    font-size: 16px;
}

#dateButton {
    min-width: 196px;
    padding: 0 18px;
}

#settingsButton {
    min-width: 48px;
    font-size: 21px;
}

#dateButton:hover,
#settingsButton:hover {
    border-color: #cfb99c;
    background: #fff8ed;
}

#avatarLabel {
    min-width: 48px;
    min-height: 48px;
    border-radius: 24px;
    background: #f6ddba;
    color: #a9141c;
    font-size: 25px;
    font-weight: 700;
}

#frame {
    background: #fffefd;
    border: 1px solid #e5d9cc;
    border-radius: 13px;
}

#label_2 {
    color: #242328;
    font-size: 20px;
    font-weight: 800;
}

#label_3,
#recommendDesc {
    color: #807973;
    font-size: 15px;
}

#mapIcon {
    min-width: 48px;
    min-height: 48px;
    border-radius: 24px;
    background: #f7e5ca;
    color: #b8151d;
    font-size: 27px;
    font-weight: 800;
}

#frame_2 {
    background: #fbf2e6;
    border: 1px solid #ead9c5;
    border-radius: 13px;
}

#mapCanvas {
    background: #fff7eb;
    border: 1px solid #ead9c5;
    border-radius: 13px;
}

#lakeFrame {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #d8edf6, stop:1 #bfe0ef);
    border: 1px solid #a8ccde;
    border-radius: 38px;
}

#mapBuilding,
#mapBuilding_2,
#mapBuilding_3,
#mapBuilding_4 {
    color: rgba(150, 100, 58, 0.28);
    font-size: 18px;
    font-weight: 700;
}

#nodeIconWest,
#nodeIconLibrary,
#nodeIconTower,
#nodeIconLake {
    min-width: 92px;
    max-width: 92px;
    min-height: 74px;
    max-height: 74px;
    border: 1px dashed #e2cdb3;
    border-radius: 16px;
    background: rgba(255, 254, 253, 0.62);
    color: #b78a55;
    font-size: 13px;
    font-weight: 800;
    padding: 8px;
}

#roadLabel,
#roadLabel_2,
#roadLabel_3,
#roadLabel_4 {
    color: rgba(143, 12, 19, 0.88);
    font-size: 26px;
    font-weight: 900;
}

#pushButton,
#pushButton_4,
#pushButton_2,
#pushButton_5 {
    min-width: 78px;
    max-width: 96px;
    min-height: 30px;
    max-height: 30px;
    border: 1px solid #ead9c5;
    border-radius: 8px;
    background: #fffefd;
    color: #b8151d;
    font-size: 14px;
    font-weight: 800;
    padding: 0 10px;
}

#pushButton:hover,
#pushButton_4:hover,
#pushButton_2:hover,
#pushButton_5:hover {
    border-color: #cfa977;
    background: #fff8ee;
}

#legendFrame,
#recommendFrame {
    background: rgba(255, 254, 253, 0.94);
    border: 1px solid #e5d9cc;
    border-radius: 10px;
}

#legendDotUnlocked {
    min-width: 14px;
    max-width: 14px;
    min-height: 14px;
    max-height: 14px;
    border-radius: 7px;
    background: #b8151d;
}

#legendDotLocked {
    min-width: 14px;
    max-width: 14px;
    min-height: 14px;
    max-height: 14px;
    border-radius: 7px;
    background: #f0c991;
}

#legendText,
#legendText_2 {
