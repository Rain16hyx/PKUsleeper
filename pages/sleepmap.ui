}

#recommendIcon {
    color: #c45a42;
    font-size: 40px;
}

#recommendTitle {
    color: #242328;
    font-size: 18px;
    font-weight: 800;
}

#recommendPlace {
    color: #b8151d;
    font-size: 20px;
    font-weight: 900;
}</string>
