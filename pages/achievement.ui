  <property name="styleSheet">
   <string notr="true">#Form {
    background: #fffdf9;
    color: #25252a;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", sans-serif;
}

QLabel {
    color: #28272c;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", sans-serif;
}

#label {
    color: #222226;
    font-size: 32px;
    font-weight: 800;
}

#dateButton,
#settingsButton {
    min-height: 44px;
    border: 1px solid #e4d8cb;
    border-radius: 9px;
    background: #fffefa;
    color: #29272a;
    font-size: 16px;
}

#dateButton {
    min-width: 196px;
    padding: 0 18px;
}

#settingsButton {
    min-width: 48px;
    font-size: 21px;
}

#dateButton:hover,
#settingsButton:hover {
    border-color: #cfb99c;
    background: #fff8ed;
}

#avatarLabel {
    min-width: 48px;
    min-height: 48px;
    border-radius: 24px;
    background: #f6ddba;
    color: #a9141c;
    font-size: 25px;
    font-weight: 700;
}

#statFrame,
#statFrame_2,
#statFrame_3,
#levelFrame,
#unlockedFrame,
#lockedFrame {
    background: #fffefd;
    border: 1px solid #e5d9cc;
