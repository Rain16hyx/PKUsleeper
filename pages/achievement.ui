    font-weight: 900;
}

#progressText {
    color: #242328;
    font-size: 16px;
    font-weight: 700;
}

#levelProgress {
    min-height: 12px;
    border: none;
    border-radius: 6px;
    background: #e8e1dc;
}

#levelProgress::chunk {
    border-radius: 6px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #eda235, stop:1 #f3bb57);
}

#achievementRow,
#achievementRow_2,
#achievementRow_3,
#achievementRow_4,
#lockedRow,
#lockedRow_2,
#lockedRow_3 {
