}

#statIcon,
#statIcon_2,
#statIcon_3,
#levelIcon {
    min-width: 72px;
    min-height: 72px;
    border-radius: 36px;
    background: #fff4e2;
    color: #eba73b;
    font-size: 42px;
    font-weight: 900;
}

#statTitle,
#statTitle_2,
#statTitle_3,
#levelTitle,
#nextTitle,
#cardTitle,
#cardTitle_2 {
    color: #242328;
    font-size: 18px;
    font-weight: 800;
}

#statValue,
