    font-weight: 900;
}

#levelDesc,
#nextDesc,
#nextDesc_2,
#rowDesc,
#rowDesc_2,
#rowDesc_3,
#rowDesc_4,
#rowDesc_5,
#rowDesc_6,
#rowDesc_7 {
